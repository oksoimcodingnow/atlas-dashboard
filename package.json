{
  "name": "atlas-dashboard",
  "displayName": "ATLAS Dashboard",
  "description": "Your personal AI-style startup dashboard for VSCode with built-in Claude AI chat",
  "version": "0.0.6",
  "publisher": "paphangkorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/oksoimcodingnow/atlas-dashboard.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other", "AI"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atlas.openDashboard",
        "title": "ATLAS: Open Dashboard"
      },
      {
        "command": "atlas.reload",
        "title": "ATLAS: Reload Dashboard"
      },
      {
        "command": "atlas.setApiKey",
        "title": "ATLAS: Set Anthropic API Key"
      },
      {
        "command": "atlas.clearApiKey",
        "title": "ATLAS: Clear Anthropic API Key"
      }
    ],
    "configuration": {
      "title": "ATLAS Dashboard",
      "properties": {
        "atlas.openOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Open ATLAS Dashboard automatically when VSCode starts"
        },
        "atlas.userName": {
          "type": "string",
          "default": "Protocol",
          "description": "Name shown in the greeting"
        },
        "atlas.sprintStartDate": {
          "type": "string",
          "default": "",
          "description": "ISO date (YYYY-MM-DD) when this sprint began. Empty hides the counter."
        },
        "atlas.sprintLength": {
          "type": "number",
          "default": 3,
          "description": "Sprint length in days"
        },
        "atlas.location": {
          "type": "string",
          "default": "URBAN",
          "description": "Location label shown in the status panel"
        },
        "atlas.journalPath": {
          "type": "string",
          "default": "JOURNAL.md",
          "description": "Relative path to the markdown file used for the Todos widget"
        },
        "atlas.projects": {
          "type": "array",
          "default": [],
          "description": "Quick-open project list. Each entry: {\"name\": \"...\", \"path\": \"absolute-path\"}",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" }
            },
            "required": ["name", "path"]
          }
        },
        "atlas.links": {
          "type": "array",
          "default": [],
          "description": "External links. Each entry: {\"name\": \"...\", \"url\": \"https://...\"}",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            },
            "required": ["name", "url"]
          }
        },
        "atlas.model": {
          "type": "string",
          "default": "claude-opus-4-7",
          "enum": [
            "claude-opus-4-7",
            "claude-opus-4-6",
            "claude-sonnet-4-6",
            "claude-haiku-4-5"
          ],
          "enumDescriptions": [
            "Most capable (slowest, $5/$25 per 1M tokens)",
            "Previous-generation Opus ($5/$25 per 1M tokens)",
            "Balanced speed and intelligence ($3/$15 per 1M tokens)",
            "Fastest and cheapest ($1/$5 per 1M tokens)"
          ],
          "description": "Claude model used by ATLAS chat"
        },
        "atlas.systemPrompt": {
          "type": "string",
          "default": "You are ATLAS — a personal AI assistant inspired by Jarvis from Iron Man. You're integrated into the user's VSCode dashboard. Be helpful, witty, and slightly formal. Keep replies concise unless asked for depth. Address the user by their preferred name when natural. You can help with code, debugging, project planning, and general dev questions.",
          "description": "System prompt that defines ATLAS's personality",
          "editPresentation": "multilineText"
        },
        "atlas.maxTokens": {
          "type": "number",
          "default": 2048,
          "description": "Max output tokens per chat response"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo no-build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0"
  }
}
